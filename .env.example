# ─── Configuración Django ────────────────────────────────────
# Genera una nueva con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambiame-en-produccion

# False en producción
DEBUG=False

# Lista separada por comas. Ejemplo producción:
#   ALLOWED_HOSTS=archivo.pietramonte.cl
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Acceso al portal ────────────────────────────────────────
# La allowlist del portal es la tabla UsuarioPortal en BD (admin de Django).
# Crea ahí los emails que pueden entrar y asígnales password + buzones visibles.

# Email del administrador (notificaciones operacionales).
PORTAL_ADMIN_EMAIL=soporte.dongo@gmail.com

# ─── Admin web (Django) ──────────────────────────────────────
# Ruta donde vive el panel de administración. Cambiala por algo
# difícil de adivinar. En producción ponla detrás de Cloudflare Access.
ADMIN_URL_PATH=admin-pm-staff

# ─── Sincronización Gmail (Fase 5) ───────────────────────────
# GMAIL_OAUTH_CLIENT_ID=
# GMAIL_OAUTH_CLIENT_SECRET=
# GMAIL_OAUTH_REFRESH_TOKEN=
# GMAIL_ARCHIVE_ACCOUNT=soporte.dongo@gmail.com
