# ════════════════════════════════════════════════════════════════════
#   .env de PRODUCCIÓN — copialo a .env en el servidor y rellena.
#
#   NUNCA subas este archivo con valores reales a git.
#   El .gitignore ya excluye .env (no .env.production.example).
# ════════════════════════════════════════════════════════════════════

# ─── Django ─────────────────────────────────────────────────────────
# Generala con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=GENERA-UNA-CLAVE-LARGA-Y-ALEATORIA

DEBUG=False

# Dominio público (separado por comas)
ALLOWED_HOSTS=archivo.pietramonte.cl


# ─── Admin de Django ─────────────────────────────────────────────────
# URL ofuscada del panel admin. Cambia el sufijo por algo ÚNICO.
# En prod, además ponlo detrás de Cloudflare Access.
ADMIN_URL_PATH=admin-pm-CAMBIA-ESTO-POR-ALGO-RANDOM


# ─── Allowlist del portal ────────────────────────────────────────────
# Estos son los Gmails que pueden entrar al portal de empleados.
# Deben coincidir con los UsuarioPortal creados en BD/admin.
PORTAL_ALLOWED_EMAILS=soporte.dongo@gmail.com,pventas.pietramonte@gmail.com,vfinanzas.pietramonte@gmail.com,ral.pietramonte@gmail.com,lvalverde.pietramonte@gmail.com

PORTAL_ADMIN_EMAIL=soporte.dongo@gmail.com


